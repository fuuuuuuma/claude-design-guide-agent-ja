{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "corporate-trust",
  "description": "ネイビー + グレーの信頼感ある企業向けデザイントークン（金融・士業）",
  "license": "CC0-1.0",
  "color": {
    "primary": "#1e3a5f",
    "secondary": "#39557a",
    "accent": "#1d7a8c",
    "bg": "#ffffff",
    "surface": "#f1f4f8",
    "ink": "#1a2230",
    "ink-mid": "#56606e",
    "line": "#d7dde6",
    "success": "#1f7a4d",
    "warning": "#a96512",
    "danger": "#a72c3a"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Noto Sans JP', 'Helvetica Neue', Arial, sans-serif",
      "body": "'Noto Sans JP', 'Helvetica Neue', Arial, sans-serif"
    },
    "size": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "22px",
      "2xl": "28px",
      "3xl": "36px",
      "4xl": "48px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "snug": 1.45,
      "normal": 1.7
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "96px"
  },
  "radius": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(26, 34, 48, 0.06)",
    "md": "0 4px 14px rgba(26, 34, 48, 0.10)",
    "lg": "0 14px 36px rgba(26, 34, 48, 0.14)"
  }
}
