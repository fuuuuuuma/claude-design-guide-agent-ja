{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "neo-brutalist",
  "description": "原色 + 太罫 + ハードシャドウのネオブルータリズム向けデザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#ffd400",
    "secondary": "#2563ff",
    "accent": "#ff5a3c",
    "bg": "#fdfdf6",
    "surface": "#ffffff",
    "ink": "#0a0a0a",
    "ink-mid": "#444444",
    "line": "#0a0a0a",
    "success": "#15a34a",
    "warning": "#d97706",
    "danger": "#e11d2e"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Archivo', 'Anton', 'Hiragino Kaku Gothic ProN', sans-serif",
      "body": "'Space Grotesk', 'Inter', 'Hiragino Kaku Gothic ProN', sans-serif",
      "mono": "'Space Mono', 'SFMono-Regular', monospace"
    },
    "size": {
      "xs": "13px",
      "sm": "15px",
      "base": "17px",
      "lg": "20px",
      "xl": "26px",
      "2xl": "36px",
      "3xl": "52px",
      "4xl": "80px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "bold": 700,
      "black": 900
    },
    "lineHeight": {
      "tight": 1.0,
      "snug": 1.25,
      "normal": 1.55
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "96px"
  },
  "radius": {
    "none": "0px",
    "sm": "0px",
    "md": "0px",
    "lg": "0px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "2px 2px 0 0 #0a0a0a",
    "md": "5px 5px 0 0 #0a0a0a",
    "lg": "8px 8px 0 0 #0a0a0a"
  },
  "border": {
    "width": "3px",
    "color": "#0a0a0a"
  }
}
