{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "minimal-saas",
  "description": "白基調 + 1アクセント（インディゴ）のミニマルSaaS向けデザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#4f46e5",
    "secondary": "#6366f1",
    "accent": "#0ea5e9",
    "bg": "#ffffff",
    "surface": "#f7f8fa",
    "ink": "#111827",
    "ink-mid": "#5b6472",
    "line": "#e3e6eb",
    "success": "#15803d",
    "warning": "#b45309",
    "danger": "#b91c1c"
  },
  "typography": {
    "fontFamily": {
      "heading": "Inter, 'Helvetica Neue', 'Hiragino Kaku Gothic ProN', Meiryo, sans-serif",
      "body": "Inter, 'Helvetica Neue', 'Hiragino Kaku Gothic ProN', Meiryo, sans-serif"
    },
    "size": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "32px",
      "4xl": "44px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "snug": 1.4,
      "normal": 1.6
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "96px"
  },
  "radius": {
    "none": "0px",
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(17, 24, 39, 0.06)",
    "md": "0 4px 12px rgba(17, 24, 39, 0.08)",
    "lg": "0 12px 32px rgba(17, 24, 39, 0.12)"
  }
}
