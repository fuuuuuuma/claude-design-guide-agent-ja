{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "soft-wellness",
  "description": "セージ / ベージュのやさしいウェルネス向けデザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#5f7a5b",
    "secondary": "#a98b6f",
    "accent": "#c98a76",
    "bg": "#f7f4ee",
    "surface": "#ece7dc",
    "ink": "#2f352c",
    "ink-mid": "#62695c",
    "line": "#dcd5c6",
    "success": "#4f7a4a",
    "warning": "#a9762a",
    "danger": "#b4584e"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Noto Serif JP', 'Zen Maru Gothic', Georgia, serif",
      "body": "'Noto Sans JP', 'Helvetica Neue', sans-serif"
    },
    "size": {
      "xs": "13px",
      "sm": "15px",
      "base": "16px",
      "lg": "19px",
      "xl": "23px",
      "2xl": "30px",
      "3xl": "40px",
      "4xl": "54px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    },
    "lineHeight": {
      "tight": 1.3,
      "snug": 1.5,
      "normal": 1.8
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "36px",
    "7": "56px",
    "8": "80px",
    "9": "120px"
  },
  "radius": {
    "none": "0px",
    "sm": "8px",
    "md": "14px",
    "lg": "22px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(47, 53, 44, 0.05)",
    "md": "0 6px 16px rgba(47, 53, 44, 0.09)",
    "lg": "0 16px 38px rgba(47, 53, 44, 0.12)"
  }
}
