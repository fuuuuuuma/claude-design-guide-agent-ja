{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "bold-startup",
  "description": "高彩度 + 極太見出しの大胆なスタートアップ向けデザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#7c3aed",
    "secondary": "#db2777",
    "accent": "#16a34a",
    "bg": "#ffffff",
    "surface": "#f4f1fb",
    "ink": "#160a2e",
    "ink-mid": "#574a6b",
    "line": "#e4def0",
    "success": "#15803d",
    "warning": "#c2410c",
    "danger": "#be123c"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Poppins', 'Montserrat', 'Hiragino Kaku Gothic ProN', sans-serif",
      "body": "'Inter', 'Hiragino Kaku Gothic ProN', Meiryo, sans-serif"
    },
    "size": {
      "xs": "13px",
      "sm": "15px",
      "base": "17px",
      "lg": "20px",
      "xl": "26px",
      "2xl": "36px",
      "3xl": "52px",
      "4xl": "76px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "lineHeight": {
      "tight": 1.05,
      "snug": 1.3,
      "normal": 1.6
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "40px",
    "7": "64px",
    "8": "96px",
    "9": "144px"
  },
  "radius": {
    "none": "0px",
    "sm": "8px",
    "md": "14px",
    "lg": "24px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 2px 6px rgba(22, 10, 46, 0.10)",
    "md": "0 10px 28px rgba(124, 58, 237, 0.18)",
    "lg": "0 24px 60px rgba(124, 58, 237, 0.24)"
  }
}
