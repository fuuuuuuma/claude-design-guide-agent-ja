{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "luxury-premium",
  "description": "黒金 / ボルドーの上質な高級感デザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#b8924f",
    "secondary": "#7a1f33",
    "accent": "#caa968",
    "bg": "#0f0d0c",
    "surface": "#1b1715",
    "ink": "#f2ece1",
    "ink-mid": "#b3a896",
    "line": "#3a322c",
    "success": "#7fae6e",
    "warning": "#d4a445",
    "danger": "#c75c5c"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Cormorant Garamond', 'Noto Serif JP', 'Times New Roman', serif",
      "body": "'Noto Serif JP', Georgia, serif"
    },
    "size": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "19px",
      "xl": "24px",
      "2xl": "32px",
      "3xl": "46px",
      "4xl": "66px"
    },
    "weight": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600
    },
    "lineHeight": {
      "tight": 1.15,
      "snug": 1.4,
      "normal": 1.75
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "28px",
    "6": "44px",
    "7": "68px",
    "8": "104px",
    "9": "152px"
  },
  "radius": {
    "none": "0px",
    "sm": "2px",
    "md": "4px",
    "lg": "8px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 3px rgba(0, 0, 0, 0.45)",
    "md": "0 8px 24px rgba(0, 0, 0, 0.55)",
    "lg": "0 20px 56px rgba(0, 0, 0, 0.65)"
  }
}
