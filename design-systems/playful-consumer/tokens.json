{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "playful-consumer",
  "description": "パステル + 丸ゴシックの陽気なコンシューマー向けデザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#e8557d",
    "secondary": "#5bb8d4",
    "accent": "#f2a93b",
    "bg": "#fffaf4",
    "surface": "#ffeef2",
    "ink": "#3a2a33",
    "ink-mid": "#7a6670",
    "line": "#f3dbe2",
    "success": "#2f8f5b",
    "warning": "#c47713",
    "danger": "#d23f57"
  },
  "typography": {
    "fontFamily": {
      "heading": "'M PLUS Rounded 1c', 'Quicksand', 'Hiragino Maru Gothic ProN', sans-serif",
      "body": "'M PLUS Rounded 1c', 'Hiragino Maru Gothic ProN', sans-serif"
    },
    "size": {
      "xs": "13px",
      "sm": "15px",
      "base": "16px",
      "lg": "19px",
      "xl": "24px",
      "2xl": "32px",
      "3xl": "44px",
      "4xl": "60px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeight": {
      "tight": 1.2,
      "snug": 1.45,
      "normal": 1.7
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "72px",
    "9": "104px"
  },
  "radius": {
    "none": "0px",
    "sm": "10px",
    "md": "18px",
    "lg": "28px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 2px 4px rgba(232, 85, 125, 0.10)",
    "md": "0 8px 20px rgba(232, 85, 125, 0.16)",
    "lg": "0 18px 44px rgba(232, 85, 125, 0.20)"
  }
}
