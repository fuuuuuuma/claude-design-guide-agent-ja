{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "warm-editorial",
  "description": "クリーム地 + セリフ見出しの温かいエディトリアル向けデザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#9a3412",
    "secondary": "#7c5c3b",
    "accent": "#b45309",
    "bg": "#fbf6ee",
    "surface": "#f4ead9",
    "ink": "#2b2118",
    "ink-mid": "#6b5d4d",
    "line": "#e2d4bf",
    "success": "#3f6212",
    "warning": "#a16207",
    "danger": "#b1402b"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Noto Serif JP', Georgia, 'Times New Roman', serif",
      "body": "'Noto Serif JP', Georgia, 'Hiragino Mincho ProN', serif"
    },
    "size": {
      "xs": "13px",
      "sm": "15px",
      "base": "17px",
      "lg": "20px",
      "xl": "24px",
      "2xl": "30px",
      "3xl": "40px",
      "4xl": "56px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "snug": 1.5,
      "normal": 1.8
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "72px",
    "9": "112px"
  },
  "radius": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "14px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(43, 33, 24, 0.06)",
    "md": "0 6px 18px rgba(43, 33, 24, 0.10)",
    "lg": "0 16px 40px rgba(43, 33, 24, 0.14)"
  }
}
