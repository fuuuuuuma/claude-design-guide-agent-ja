{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "dark-developer",
  "description": "ダークモード開発者向けの近未来デザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#6ea8fe",
    "secondary": "#7ee7c7",
    "accent": "#c08cff",
    "bg": "#0d1117",
    "surface": "#161b22",
    "ink": "#e6edf3",
    "ink-mid": "#9aa4b2",
    "line": "#2a313c",
    "success": "#4ade80",
    "warning": "#fbbf57",
    "danger": "#ff6b6b"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Space Grotesk', 'Inter', 'Hiragino Kaku Gothic ProN', sans-serif",
      "body": "'Inter', 'Hiragino Kaku Gothic ProN', sans-serif",
      "mono": "'JetBrains Mono', 'SFMono-Regular', Consolas, monospace"
    },
    "size": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "22px",
      "2xl": "28px",
      "3xl": "38px",
      "4xl": "52px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "snug": 1.45,
      "normal": 1.65
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "96px"
  },
  "radius": {
    "none": "0px",
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0, 0, 0, 0.40)",
    "md": "0 6px 18px rgba(0, 0, 0, 0.50)",
    "lg": "0 16px 40px rgba(0, 0, 0, 0.60)"
  }
}
