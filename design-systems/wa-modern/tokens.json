{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "wa-modern",
  "description": "藍 / 墨 / 朱、余白を広く取った和モダンデザイントークン",
  "license": "CC0-1.0",
  "color": {
    "primary": "#1f3a5f",
    "secondary": "#3c5a4a",
    "accent": "#c0392b",
    "bg": "#f6f4ef",
    "surface": "#ece7dc",
    "ink": "#1b1b1a",
    "ink-mid": "#5a574f",
    "line": "#d8d2c5",
    "success": "#3f6b46",
    "warning": "#a8742a",
    "danger": "#a73228"
  },
  "typography": {
    "fontFamily": {
      "heading": "'Shippori Mincho', 'Noto Serif JP', 'Yu Mincho', serif",
      "body": "'Noto Serif JP', 'Yu Mincho', serif"
    },
    "size": {
      "xs": "13px",
      "sm": "15px",
      "base": "16px",
      "lg": "19px",
      "xl": "24px",
      "2xl": "32px",
      "3xl": "42px",
      "4xl": "58px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.3,
      "snug": 1.6,
      "normal": 1.9
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "28px",
    "6": "44px",
    "7": "68px",
    "8": "100px",
    "9": "148px"
  },
  "radius": {
    "none": "0px",
    "sm": "2px",
    "md": "4px",
    "lg": "8px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(27, 27, 26, 0.05)",
    "md": "0 6px 18px rgba(27, 27, 26, 0.08)",
    "lg": "0 16px 40px rgba(27, 27, 26, 0.12)"
  }
}
